---
import BrandBadge from './BrandBadge.astro';
import { ExternalLink, Triangle } from '@lucide/astro';
import { Image } from 'astro:assets';
import cursorLogo from '../assets/cursor-logo.svg';
import supabaseLogo from '../assets/supabase.png';
import githubLogo from '../assets/github.svg';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const accounts = [
  {
    id: 1,
    name: 'GitHub',
    url: 'https://github.com/',
    colorClass: 'bg-zinc-800 text-white border-zinc-700',
    imageAsset: githubLogo,
    instructions: t('acc.1.inst'),
    placeholder: t('acc.1.place')
  },
  {
    id: 2,
    name: 'Cursor',
    url: 'https://cursor.com/',
    colorClass: 'bg-white text-black border-zinc-200',
    imageAsset: cursorLogo,
    instructions: t('acc.2.inst'),
    placeholder: t('acc.2.place')
  },
  {
    id: 3,
    name: 'Supabase',
    url: 'https://supabase.com/',
    colorClass: 'bg-brand-supabase text-white border-brand-supabase-dark',
    imageAsset: supabaseLogo,
    instructions: t('acc.3.inst'),
    placeholder: t('acc.3.place')
  },
  {
    id: 4,
    name: 'Vercel',
    url: 'https://vercel.com/',
    colorClass: 'bg-black text-white border-zinc-800',
    icon: Triangle,
    instructions: t('acc.4.inst'),
    placeholder: t('acc.4.place')
  }
];
---

<section class="py-24 relative border-b border-white/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white mb-4">
        {t('acc.title')}
      </h2>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto">
        {t('acc.desc')}
      </p>
    </div>

    <div class="max-w-5xl mx-auto space-y-12">
      {accounts.map((account, index) => {
        const Icon = account.icon;
        return (
        <div class="relative flex flex-col md:flex-row gap-8 items-start group">
          {index !== accounts.length - 1 && (
            <div class="absolute left-6 top-16 bottom-[-3rem] w-px bg-zinc-800 group-hover:bg-zinc-700 transition-colors hidden md:block"></div>
          )}
          
          <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-full bg-zinc-900 border border-zinc-800 text-xl font-bold text-zinc-400 relative z-10 group-hover:border-white/20 group-hover:text-white transition-all">
            {account.id}
          </div>

          <div class="flex-1 w-full bg-gradient-to-b from-white/[0.04] to-transparent p-px rounded-2xl">
            <div class="bg-[#0a0a0a] rounded-2xl p-6 sm:p-8 border border-white/5 hover:border-white/10 transition-colors h-full flex flex-col xl:flex-row gap-8 items-center">
              
              <div class="flex-1 space-y-4">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class={`p-2 rounded-lg ${account.name === 'Cursor' || account.name === 'GitHub' ? 'bg-white text-black' : account.name === 'Supabase' ? 'bg-zinc-900 border border-[#3ECF8E]/20 text-[#3ECF8E]' : 'bg-black text-white border border-zinc-800'}`}>
                      {Icon ? (
                        <Icon class="w-6 h-6" />
                      ) : account.imageAsset && (
                        <Image src={account.imageAsset} alt={account.name} class="w-6 h-6 object-contain" />
                      )}
                    </div>
                    <h3 class="text-2xl font-semibold text-white">{account.name}</h3>
                  </div>
                  <BrandBadge name={account.name} colorClass={account.colorClass} />
                </div>
                
                <p class="text-zinc-400 text-lg">
                  {account.instructions}
                </p>

                <a 
                  href={account.url} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-medium text-white hover:text-zinc-300 transition-colors group/link"
                >
                  {t('acc.link')} {account.name}
                  <ExternalLink class="w-4 h-4 opacity-50 group-hover/link:opacity-100 transition-opacity" />
                </a>
              </div>

              <div class="w-full xl:w-[400px] flex-shrink-0">
                <div class="bg-[#121212] border border-zinc-800 w-full aspect-video rounded-xl flex items-center justify-center text-zinc-500 font-medium text-sm text-center p-6 shadow-inner relative overflow-hidden group/image">
                  <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/5 to-transparent opacity-0 group-hover/image:opacity-100 transition-opacity"></div>
                  <span>{account.placeholder}</span>
                </div>
              </div>

            </div>
          </div>
        </div>
      );
    })}
    </div>
  </div>
</section>
