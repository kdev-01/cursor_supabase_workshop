---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Wifi, ShieldCheck, Zap } from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 overflow-hidden border-b border-white/5">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] no-print"></div>
  
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sm text-zinc-300 mb-8 backdrop-blur-sm animate-fade-in-up">
      <Zap class="w-4 h-4 text-brand-supabase" />
      <span>{t('hero.badge')}</span>
    </div>

    <h1 class="mx-auto max-w-4xl font-display text-5xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-200 to-zinc-400 sm:text-7xl mb-6">
      {t('hero.title.1')} <br/><span class="text-white">{t('hero.title.2')}</span>
    </h1>
    
    <p class="mx-auto max-w-2xl text-lg sm:text-xl text-zinc-400 mb-12">
      {t('hero.desc')}
    </p>

    <div class="mx-auto max-w-md text-left bg-gradient-to-b from-white/[0.08] to-transparent p-px rounded-2xl shadow-2xl backdrop-blur-md">
      <div class="bg-[#0f0f0f] rounded-2xl p-6 sm:p-8 border border-white/5 relative overflow-hidden group hover:border-white/10 transition-colors">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
          <Wifi class="w-24 h-24 text-white" />
        </div>
        
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2.5 bg-white/10 rounded-lg border border-white/5 text-white">
              <Wifi class="w-5 h-5" />
            </div>
            <h2 class="text-xl font-semibold text-white">{t('wifi.title')}</h2>
          </div>
          
          <div class="space-y-4">
            <div class="flex justify-between items-center py-2 border-b border-white/5">
              <span class="text-zinc-500 font-medium text-sm uppercase tracking-wider">{t('wifi.network.label')}</span>
              <span class="text-white font-mono font-medium">{t('wifi.network.val')}</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-white/5">
              <span class="text-zinc-500 font-medium text-sm uppercase tracking-wider">{t('wifi.user.label')}</span>
              <span class="text-white font-mono font-medium">{t('wifi.user.val')}</span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-zinc-500 font-medium text-sm uppercase tracking-wider">{t('wifi.pass.label')}</span>
              <span class="text-white font-mono font-medium">{t('wifi.pass.val')}</span>
            </div>
          </div>

          <div class="mt-6 flex items-start gap-3 p-4 bg-brand-supabase/5 rounded-xl border border-brand-supabase/10">
            <ShieldCheck class="w-5 h-5 text-brand-supabase flex-shrink-0 mt-0.5" />
            <p class="text-sm text-brand-supabase/90 leading-relaxed">
              {t('wifi.note')}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
