---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Wifi, ShieldCheck, Zap, Copy, Check } from '@lucide/astro';
import MarketLabCountdown from './MarketLabCountdown.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 overflow-hidden border-b border-white/5">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] no-print"></div>
  
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sm text-zinc-300 mb-8 backdrop-blur-sm animate-fade-in-up">
      <Zap class="w-4 h-4 text-brand-supabase" />
      <span>{t('hero.badge')}</span>
    </div>

    <MarketLabCountdown />

    <h1 class="mx-auto max-w-4xl font-display text-5xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-200 to-zinc-400 sm:text-7xl mb-6">
      {t('hero.title.1')} <br/><span class="text-white">{t('hero.title.2')}</span>
    </h1>
    
    <p class="mx-auto max-w-2xl text-lg sm:text-xl text-zinc-400 mb-12">
      {t('hero.desc')}
    </p>

    <div class="mx-auto max-w-md text-left relative group/card">
      <div class="absolute -inset-1 bg-gradient-to-r from-brand-supabase/30 to-brand-supabase/0 rounded-[2rem] blur-xl opacity-20 group-hover/card:opacity-40 transition duration-1000"></div>
      
      <div class="bg-[#0a0a0a]/80 backdrop-blur-2xl rounded-[2rem] p-6 sm:p-8 border border-white/10 relative overflow-hidden shadow-[inset_0_1px_0_0_rgba(255,255,255,0.1),0_8px_32px_0_rgba(0,0,0,0.5)]">
        <div class="absolute -top-32 -right-32 w-64 h-64 bg-brand-supabase/20 rounded-full blur-[80px]"></div>
        <div class="absolute top-0 right-0 p-8 opacity-5 mix-blend-overlay">
          <Wifi class="w-32 h-32 text-white transform rotate-12" />
        </div>
        
        <div class="relative z-10">
          <div class="flex items-center gap-4 mb-8">
            <div class="p-3 bg-gradient-to-br from-white/10 to-white/0 rounded-xl border border-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)] backdrop-blur-md">
              <Wifi class="w-6 h-6 text-white" />
            </div>
            <div>
              <h2 class="text-xl font-bold text-white tracking-tight">{t('wifi.title')}</h2>
              <div class="h-1 w-8 bg-brand-supabase rounded-full mt-1.5 opacity-80"></div>
            </div>
          </div>
          
          <div class="space-y-3">
            <div class="flex flex-col py-3 px-4 bg-white/[0.02] rounded-xl border border-white/5 hover:bg-white/[0.04] transition-colors shadow-inner">
              <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1">{t('wifi.network.label')}</span>
              <span class="text-white font-mono text-base tracking-tight" id="wifi-network">{t('wifi.network.val')}</span>
            </div>
            
            <div class="flex justify-between items-center py-3 px-4 bg-white/[0.02] rounded-xl border border-white/5 group/row hover:bg-white/[0.04] transition-colors shadow-inner">
              <div class="flex flex-col">
                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1">{t('wifi.user.label')}</span>
                <span class="text-brand-supabase font-mono text-base tracking-tight" id="wifi-user">{t('wifi.user.val')}</span>
              </div>
              <button class="copy-btn flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 text-zinc-400 hover:text-white hover:bg-white/10 border border-white/5 transition-all opacity-0 group-hover/row:opacity-100 focus:opacity-100 shadow-sm" data-target="wifi-user" aria-label="Copy user">
                <Copy class="w-4 h-4" />
              </button>
            </div>

            <div class="flex justify-between items-center py-3 px-4 bg-white/[0.02] rounded-xl border border-white/5 group/row hover:bg-white/[0.04] transition-colors shadow-inner">
              <div class="flex flex-col">
                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-1">{t('wifi.pass.label')}</span>
                <span class="text-brand-supabase font-mono text-base tracking-tight" id="wifi-pass">{t('wifi.pass.val')}</span>
              </div>
              <button class="copy-btn flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 text-zinc-400 hover:text-white hover:bg-white/10 border border-white/5 transition-all opacity-0 group-hover/row:opacity-100 focus:opacity-100 shadow-sm" data-target="wifi-pass" aria-label="Copy password">
                <Copy class="w-4 h-4" />
              </button>
            </div>
          </div>

          <div class="mt-8 relative overflow-hidden rounded-xl bg-gradient-to-r from-brand-supabase/10 to-transparent border border-brand-supabase/20 p-4">
            <div class="absolute left-0 top-0 bottom-0 w-1 bg-brand-supabase shadow-[0_0_8px_rgba(var(--brand-supabase),0.8)]"></div>
            <div class="flex gap-3">
              <ShieldCheck class="w-5 h-5 text-brand-supabase flex-shrink-0 mt-0.5 opacity-80" />
              <p class="text-sm text-zinc-300 leading-relaxed font-medium">
                {t('wifi.note')}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const copyBtns = document.querySelectorAll('.copy-btn');
  copyBtns.forEach(btn => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      const targetEl = document.getElementById(targetId);
      if (targetEl && targetEl.textContent) {
        try {
          await navigator.clipboard.writeText(targetEl.textContent);
          const originalHTML = btn.innerHTML;
          btn.innerHTML = '<svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
          setTimeout(() => {
            btn.innerHTML = originalHTML;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      }
    });
  });
</script>
