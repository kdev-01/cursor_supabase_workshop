---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Download, Navigation } from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-24 relative border-b border-white/5">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white mb-4">
        {t('install.title')}
      </h2>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto">
        {t('install.desc')}
      </p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-b from-white/[0.04] to-transparent p-px rounded-3xl">
        <div class="bg-[#0f0f0f] rounded-3xl p-8 sm:p-12 border border-white/5 flex flex-col md:flex-row gap-12 items-center">
          
          <div class="flex-1 space-y-6">
            <div class="flex items-center gap-4 mb-2">
              <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center shadow-lg border border-white/10 text-black">
                <Navigation class="w-7 h-7" />
              </div>
              <div>
                <h3 class="text-2xl font-bold text-white">Cursor IDE</h3>
                <span class="text-zinc-500 text-sm">{t('install.cursor.desc')}</span>
              </div>
            </div>
            
            <p class="text-zinc-300 text-lg leading-relaxed">
              {t('install.cursor.text')}
            </p>
            
            <a 
              href="https://cursor.com/" 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white text-black font-semibold hover:bg-zinc-200 transition-colors shadow-xl shadow-white/10"
            >
              <Download class="w-5 h-5" />
              {t('install.btn')}
            </a>
          </div>

          <div class="w-full md:w-1/2 flex-shrink-0">
            <div class="bg-zinc-900 border border-zinc-800 w-full aspect-video rounded-2xl flex items-center justify-center text-zinc-500 font-medium text-center p-6 shadow-2xl overflow-hidden relative group">
              <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <span>{t('install.placeholder')}</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
