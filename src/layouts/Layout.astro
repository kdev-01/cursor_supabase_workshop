---
import "../styles/global.css";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	lang?: string;
}

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const { 
	title = t('site.title'), 
	description = t('site.description'),
	lang = currentLang 
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" media="(prefers-color-scheme: light)" href="/CUBE_2D_LIGHT.svg" />
		<link rel="icon" type="image/svg+xml" media="(prefers-color-scheme: dark)" href="/CUBE_2D_DARK.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<slot />
	</body>
</html>
