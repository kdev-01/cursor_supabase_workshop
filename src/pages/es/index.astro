---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MarketLabHero from '../../components/MarketLabHero.astro';
import MarketLabInstall from '../../components/MarketLabInstall.astro';
import MarketLabAccounts from '../../components/MarketLabAccounts.astro';
import MarketLabCTA from '../../components/MarketLabCTA.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="MarketLab Workshop" lang={lang}>
  <Navbar />
  
  <main class="flex-grow">
    <MarketLabHero />
    <MarketLabInstall />
    <MarketLabAccounts />
    <MarketLabCTA />
  </main>

  <Footer />
</Layout>
